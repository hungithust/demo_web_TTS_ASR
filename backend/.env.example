# Set MOCK_MODE=false and the gateway URLs to use the real engine.
MOCK_MODE=true
# OpenAI-compatible Speech Gateway endpoints (full paths):
TTS_ENGINE_URL=https://<gateway-host>/v1/audio/speech
ASR_ENGINE_URL=https://<gateway-host>/v1/audio/transcriptions
ENGINE_API_KEY=
TTS_VOICE=alloy
CORS_ORIGINS=http://localhost:3000
PORT=8000
ENGINE_TIMEOUT=60
EVAL_SESSION_SIZE=15
